# DeltaScribe Edge Backend - Environment Variables
# Copy to .env and fill in values

# Debug mode
DEBUG=true

# Paths (local development - override Docker defaults)
DATA_DIR=./data
DEMO_PATIENTS_DIR=./data/demo_patients
GUIDELINES_DIR=./data/guidelines

# Model settings
MODEL_NAME=google/medgemma-4b-it
DEVICE=auto
MAX_NEW_TOKENS=512

# GGUF Settings (fast inference)
USE_GGUF=true
GGUF_MODEL_PATH=./data/models/medgemma-4b-it-Q4_K_M.gguf
GGUF_N_CTX=4096
GGUF_N_THREADS=8

# Logging
LOG_LEVEL=DEBUG
LOG_JSON=false

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3010"]

# HuggingFace token (required for model download)
HF_TOKEN=your_hf_token_here
